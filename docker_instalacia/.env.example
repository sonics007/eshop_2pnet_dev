# ============================================
# ESHOP - Docker Environment Variables
# ============================================
#
# Skopíruj tento súbor ako .env a uprav hodnoty
# cp .env.example .env
#
# ============================================

# Port na ktorom bude eshop bežať
PORT=3000

# Databáza (SQLite - cesta v kontajneri)
DATABASE_URL=file:/app/data/eshop.db

# Node environment
NODE_ENV=production

# JWT Secret pre autentifikáciu (vygeneruj vlastný!)
# Príkaz: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production

# Admin credentials (pre prvé prihlásenie)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ABRA FlexiBee integrácia (voliteľné)
# FLEXIBEE_URL=https://demo.flexibee.eu
# FLEXIBEE_COMPANY=demo
# FLEXIBEE_USERNAME=admin
# FLEXIBEE_PASSWORD=adminadmin

# Chat widget (voliteľné)
# CHATWOOT_BASE_URL=https://app.chatwoot.com
# CHATWOOT_WEBSITE_TOKEN=your-token

# Email SMTP (voliteľné)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@example.com
