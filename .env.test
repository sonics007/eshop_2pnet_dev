# Test Environment Variables
# Tento súbor sa používa pri spúšťaní testov

# Test databáza - izolovaná od produkčnej
DATABASE_URL="file:./prisma/test.db"

# JWT secret pre testy
JWT_SECRET="test-jwt-secret-key-do-not-use-in-production"
ADMIN_JWT_SECRET="test-admin-jwt-secret-key"

# Disable 2FA pre testy
DISABLE_2FA_FOR_TESTS="true"

# Test email (neposiela skutočné emaily)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""

# Base URL pre testy
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Node environment
NODE_ENV="test"
